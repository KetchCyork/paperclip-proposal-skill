FIRM_NAME=TSP

# Memory brain (agent-memory-mesh) — for retrieving past proposals + style.
MEMORY_URL=http://127.0.0.1:8377
MEMORY_API_KEY=

# Model for analysis + drafting. "ollama" (local/private) or "openrouter".
PROPOSAL_PROVIDER=ollama
PROPOSAL_CHAT_MODEL=llama3.1
OPENROUTER_API_KEY=

# Embeddings always run on Ollama (to match the brain's vector space).
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text

# Storage (defaults under ~/.paperclip-proposal).
PROPOSAL_PROFILES_DIR=
PROPOSAL_OUTPUT_DIR=
